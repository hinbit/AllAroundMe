PORT='4090'
NODE_ENV='production'
APP_ENV='production'
PUBLIC_URL='https://allaroundme.seach.co.il'
API_BASE_URL='/api'

# Eshkolot-alphon public API. Either the alphon's local port on this VPS
# (preferred) or an existing public origin, e.g. 'https://eshkolot.seach.co.il/api'
ESHKOLOT_API_URL='http://127.0.0.1:3070/api'

DB_MACHINE_ID='vps'
DB_HOST='127.0.0.1'
DB_PORT='3306'
MYSQL_HOST='127.0.0.1'
MYSQL_PORT='3306'
DB_NAME='allaroundme'
DB_USER='allaroundme'
DB_PASSWORD='CHANGE-ME'
MYSQL_DATABASE='allaroundme'
MYSQL_USER='allaroundme'
MYSQL_PASSWORD='CHANGE-ME'

JWT_SECRET='CHANGE-ME-LONG-RANDOM'
TOKEN_TTL_HOURS='12'

DEFAULT_DOCTOR_EMAIL='doctor@allaroundme.local'
DEFAULT_DOCTOR_PASSWORD='CHANGE-ME'

PROFILE_TTL_DAYS='90'

# WhatsApp delivery — set to 'cloud' with real Meta credentials in production
