PORT='4090'
NODE_ENV='development'
APP_ENV='development'
PUBLIC_URL='http://localhost:4090'
API_BASE_URL='/api'

# Eshkolot-alphon public API (companion app on the same VPS / local machine)
ESHKOLOT_API_URL='http://127.0.0.1:3070/api'

# MySQL
DB_MACHINE_ID='local-current'
DB_HOST='127.0.0.1'
DB_PORT='3306'
MYSQL_HOST='127.0.0.1'
MYSQL_PORT='3306'
DB_NAME='allaroundme'
DB_USER='allaroundme'
DB_PASSWORD='allaroundme-secret'
MYSQL_DATABASE='allaroundme'
MYSQL_USER='allaroundme'
MYSQL_PASSWORD='allaroundme-secret'

JWT_SECRET='dev-change-me-in-production-please'
TOKEN_TTL_HOURS='12'

# Seeded demo doctor accounts (db:seed)
DEFAULT_DOCTOR_EMAIL='doctor@allaroundme.local'
DEFAULT_DOCTOR_PASSWORD='Doctor!2026'

# Cookie / profile lifetime (days without use before the user starts over)
PROFILE_TTL_DAYS='90'

# --- What this deployment looks like (served to the browser by /api/config) ---
# CLIENT_THEME — which theme a plain visit gets (client/themes/<name>/theme.json).
#   Empty = the client's own default, 'allaroundme'. ?theme=<name> still wins.
CLIENT_THEME='allaroundme'
# UI_TYPE — which interface the app runs on. The types are defined server-side in
# server/env.js (config.uiTypes):
#   1 = the built-in radial map over OSM tiles (no key, no third party)
#   2 = google_based — Google Maps JS API, needs GOOGLE_MAPS_BROWSER_KEY
# A value here OVERRIDES the theme's own ui.type, so a deployment can put every
# theme on Google Maps without editing any of them. Empty = let each theme decide.
# ?ui=1|2 still wins, for testing.
UI_TYPE='2'

# WhatsApp delivery (questionnaires, OTP codes, doctor digests)
#   log       = dev: messages are printed to the server log
#   cloud     = Meta WhatsApp Cloud API (needs WHATSAPP_TOKEN + WHATSAPP_PHONE_ID)
#   webhook   = POST every message to your own bot (WHATSAPP_BOT_URL)
#   dialog360 = hand a JSON envelope to the system that owns the 360dialog
#               number and actually delivers it (see below)
WHATSAPP_MODE='log'
WHATSAPP_TOKEN=''
WHATSAPP_PHONE_ID=''
WHATSAPP_VERIFY_TOKEN='aam-verify'
WHATSAPP_BOT_URL=''

# 360dialog: the platform's identity desk. We never call 360dialog ourselves —
# we POST the 'allaroundme.wa.v1' envelope (server/services/waTransport.js) to
# the executor, which performs the send and posts replies back to
# <PUBLIC_URL>/api/hooks/wa-inbound.
# The number verifies WHO someone is; clinical content never flows through it.
DIALOG360_EXECUTOR_URL=''
DIALOG360_EXECUTOR_TOKEN=''
DIALOG360_NUMBER=''             # the system-controlled WhatsApp number (972...)
DIALOG360_INBOUND_SECRET=''     # echoed in the envelope so replies can be trusted

# Desk QR: how long a printed code stays scannable. Short = a photo of the code
# is worthless; long enough to survive a slow scan.
QR_WINDOW_SEC='120'

# What this database keeps once answers reach the doctor's own WhatsApp/email:
#   deidentify = drop patient name/phone/email/profile link, keep de-identified
#                answers for the aggregate report (the regulatory default)
#   full       = keep everything — only for a clinic self-hosting this, where
#                this database IS the doctor's own record
PHI_RETENTION='deidentify'

# Email (doctor digests, email questionnaires). Empty host = log mode.
SMTP_HOST=''
SMTP_PORT='587'
SMTP_USER=''
SMTP_PASS=''
SMTP_FROM='AllAroundMe <no-reply@allaroundme.local>'

# Scheduler: outbox dispatch every minute + daily doctor digest from this hour
SCHEDULER_ENABLED='1'
DIGEST_HOUR='8'
