# Third-party credentials for AllAroundMe.
#
# Copy to `.env.credentials` and fill in the real values. That file is gitignored
# and must stay that way: everything below is a live secret, and a key committed
# to a repo is a leaked key — history keeps it long after the file is deleted,
# and bots scan public and private forks alike for exactly these prefixes.
#
# On the VPS, Multidev writes these from its own env store; nothing here is baked
# into the client bundle except values explicitly marked PUBLIC.

# --- Google Maps ---
# נדרש רק לערכות נושא עם ui.type = 2 (google_based) — ראו client/themes/
# יש לקבל מפתח מ: https://console.cloud.google.com/apis/credentials
# יש להפעיל את Maps JavaScript API ב-Google Cloud Console
#
# PUBLIC: a Maps JS key is visible to any visitor by design — it is restricted,
# not hidden. Restrict it by HTTP referrer (https://allaround.seach.co.il/*) and
# to the Maps JavaScript API only, or anyone can spend your quota.
#
# This is the key /api/config hands to the browser. VITE_GOOGLE_MAPS_API_KEY is
# read as a fallback under its old name; new setups should use the clear one.
# Leave it empty and ui.type 2 themes simply fall back to the built-in map.
GOOGLE_MAPS_BROWSER_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# ===== אימות Google OAuth =====
# מפעיל אפשרות התחברות עם Gmail
ALLOW_GMAIL_AUTH=TRUE

# Google OAuth 2.0 Credentials
# יש לקבל מ: https://console.cloud.google.com/apis/credentials
# הפעל את: Google Identity Services
# אם Google Cloud Console עדיין מציג Google+ API היסטורי, אפשר להשאיר רק את
# Google Identity Services פעיל כל עוד ה-OAuth client וה-consent screen תקינים.
# The client ID is public; the client SECRET is not — it must never reach the
# browser or the repo. Server-side only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server-side Google keys. Restrict each by API + IP in the Cloud Console.
GOOGLE_MAPS_API_KEY=
GOOGLE_SPEECH_API_KEY=
